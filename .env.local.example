# ─────────────────────────────────────────────────────────────
# GrowthBook (Cloud) configuration
# Copy this file to `.env.local` and paste in your own values.
#
# Get these from: GrowthBook Cloud → SDK Connections → (your connection)
#
# IMPORTANT: use the CLIENT key (starts with `sdk-`), NOT the secret key.
# The client key is read-only and safe to ship to the SDK.
# ─────────────────────────────────────────────────────────────

# The GrowthBook CDN host for Cloud accounts (leave as-is for Cloud).
GROWTHBOOK_API_HOST=https://cdn.growthbook.io

# Your SDK Connection client key, e.g. sdk-abc123...
GROWTHBOOK_CLIENT_KEY=sdk-REPLACE_ME
